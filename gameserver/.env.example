# UDP port the game server listens on
UDP_PORT=7777

# Django backend base URL (internal Docker network)
DJANGO_URL=http://backend:8001

# Path to the RSA public key (PEM) used to validate player JWTs offline
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# Shared secret for HMAC-signed webhook calls to Django
DJANGO_WEBHOOK_SECRET=change-this-in-production

# World dimensions in centimetres
WORLD_WIDTH=10000
WORLD_HEIGHT=10000

# Spatial grid cell size in centimetres (50 m)
SPATIAL_CELL_SIZE=5000
