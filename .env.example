# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_DB=projeto_ravenna
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# ── Django ─────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=changeme_at_least_50_random_chars
DEBUG=False
ALLOWED_HOSTS=api.projetoravenna.cloud,localhost
CORS_ALLOWED_ORIGINS=https://projetoravenna.cloud
CSRF_TRUSTED_ORIGINS=https://api.projetoravenna.cloud
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=63072000
SECURE_HSTS_PRELOAD=True

# ── Email encryption ───────────────────────────────────────────────────────────
EMAIL_SETTINGS_ENCRYPTION_SALT=changeme_32_random_bytes_base64

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1

# ── JWT RS256 key pair (PEM, single-line with \n escapes) ──────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Game server ────────────────────────────────────────────────────────────────
# CRITICAL: change before production — default 'changeme' disables webhook auth
DJANGO_WEBHOOK_SECRET=changeme_strong_secret_min_32_chars
GAMESERVER_UDP_PORT=7777
WORLD_WIDTH=10000
WORLD_HEIGHT=10000
SPATIAL_CELL_SIZE=5000

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.projetoravenna.cloud
NEXT_PUBLIC_SITE_URL=https://projetoravenna.cloud

# ── Nginx / SSL ────────────────────────────────────────────────────────────────
DOMAIN=projetoravenna.cloud
# Path on the host where Let's Encrypt certs live (mapped to /etc/nginx/ssl in container)
SSL_CERT_PATH=/etc/letsencrypt/live/projetoravenna.cloud

# ── Throttling ─────────────────────────────────────────────────────────────────
REST_THROTTLE_ANON=30/min
REST_THROTTLE_USER=120/min
REST_THROTTLE_LOGIN=10/min
REST_THROTTLE_OTP=50/hour
REST_THROTTLE_GAMESERVER=120/min

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Email ──────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=no-reply@projetoravenna.cloud

# ── PostgreSQL Backup ──────────────────────────────────────────────────────────
# Host path where backup files are stored (mapped to /backups inside container)
BACKUP_HOST_PATH=./backups
# Number of daily backup files to keep before pruning
BACKUP_KEEP_DAYS=7
# Interval between automatic backups in seconds (default 86400 = 24 h)
BACKUP_INTERVAL_SECONDS=86400

# ── CI / Build metadata (set automatically by GitHub Actions) ─────────────────
APP_VERSION=
APP_BUILD_SHA=
APP_BUILD_TIME=
