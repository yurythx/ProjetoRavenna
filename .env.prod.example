# =============================================================================
# Projeto Ravenna — Production Environment Variables
# =============================================================================
# Copy this file to .env.prod and fill in ALL values before running.
# Never commit .env.prod to version control.
#
# Generate secrets:
#   DJANGO_SECRET_KEY    -> python -c "import secrets; print(secrets.token_urlsafe(64))"
#   EMAIL_SALT           -> python -c "import secrets; print(secrets.token_urlsafe(32))"
#   DJANGO_WEBHOOK_SECRET-> python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# --- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_python_secrets
EMAIL_SETTINGS_ENCRYPTION_SALT=CHANGE_ME_generate_with_python_secrets
DEBUG=False

# --- Database (Postgres) ---------------------------------------------------
POSTGRES_DB=projeto_ravenna
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# --- Hosts & CORS ----------------------------------------------------------
# Comma-separated list of valid domain names and IPs
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- SSL (set to False if terminating SSL upstream via proxy/CDN) ----------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=True

# --- Email -----------------------------------------------------------------
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/api
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- Game Server -----------------------------------------------------------
GAMESERVER_UDP_PORT=7777
DJANGO_WEBHOOK_SECRET=CHANGE_ME_generate_with_python_secrets
WORLD_WIDTH=10000
WORLD_HEIGHT=10000
SPATIAL_CELL_SIZE=5000

# --- Throttling (optional, defaults shown) ---------------------------------
REST_THROTTLE_ANON=30/min
REST_THROTTLE_USER=120/min
REST_THROTTLE_LOGIN=10/min
REST_THROTTLE_OTP=50/hour

# --- JWT RSA Keys (optional — auto-generated if omitted) -------------------
# Provide inline PEM content to persist keys across rebuilds without a volume.
# Leave empty to auto-generate (keys are stored in the keys_data volume).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- Observability (optional) ----------------------------------------------
SENTRY_DSN=
