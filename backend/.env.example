DJANGO_SECRET_KEY=change-this-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=False

# Build/version (optional)
APP_VERSION=
APP_BUILD_SHA=
APP_BUILD_TIME=

# PostgreSQL
POSTGRES_DB=projeto_ravenna
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# Celery (optional — defaults to REDIS_URL with db/2)
CELERY_BROKER_URL=redis://redis:6379/2
# Channel Layers (optional — defaults to REDIS_URL with db/3)
CHANNEL_LAYER_URL=redis://redis:6379/3

# Observability (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_FORMAT=json
DJANGO_LOG_LEVEL=INFO

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=

# Default support user
CREATE_DEFAULT_SUPPORT_USER=True
SUPPORT_USER_USERNAME=suporte
SUPPORT_USER_EMAIL=suporte@ravenna.local
SUPPORT_USER_PASSWORD=suporte123

# Email/SMTP encryption (must be changed in production)
EMAIL_SETTINGS_ENCRYPTION_SALT=change-me-email-salt

# OTP settings
ACCOUNTS_EMAIL_VERIFY_CODE_EXPIRES_MINUTES=10
ACCOUNTS_PASSWORD_RESET_CODE_EXPIRES_MINUTES=10
ACCOUNTS_OTP_MAX_ATTEMPTS=10
ACCOUNTS_OTP_COOLDOWN_SECONDS=60
ACCOUNTS_OTP_MAX_PER_HOUR=10
ACCOUNTS_OTP_MAX_PER_HOUR_PER_IP=50
ACCOUNTS_OTP_CLEANUP_AFTER_DAYS=7

# Throttling
REST_THROTTLING_ENABLED=False
REST_THROTTLE_ANON=300/min
REST_THROTTLE_USER=600/min
REST_THROTTLE_OTP=50/hour
REST_THROTTLE_LOGIN=10/min

# Leaderboard
LEADERBOARD_SIZE=100

# Game server webhook (shared secret with the C# headless server)
DJANGO_WEBHOOK_SECRET=change-this-in-production

# Security (production only)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_PRELOAD=True
